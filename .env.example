# Rename this file to .env and fill in real values before running the app

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Must be at least 32 characters for JWT signing security
JWT_SECRET=replace_me_with_a_long_random_secret_at_least_32_chars

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for the API server
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
